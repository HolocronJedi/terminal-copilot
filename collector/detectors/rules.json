{
  "safe_windows_names": [
    "csrss.exe", "wininit.exe", "winlogon.exe", "lsass.exe", "services.exe",
    "svchost.exe", "explorer.exe", "dwm.exe", "smss.exe", "spoolsv.exe"
  ],
  "safe_linux_names": [
    "systemd", "kthreadd", "rcu_gp", "rcu_par_gp", "migration", "ksoftirqd", "kworker",
    "watchdog", "cpuhp", "kdevtmpfs", "kthread", "kcompactd", "kswapd", "khugepaged",
    "jbd2", "ext4-rsv-conver", "systemd-journald", "systemd-udevd", "systemd-logind",
    "dbus-daemon", "NetworkManager", "rsyslogd", "cron", "crond", "sshd", "agetty",
    "login", "bash", "zsh", "sh", "sudo", "init", "launchd", "kernel_task",
    "notifyd", "logd", "opendirectoryd", "runningboardd", "distnoted", "cfprefsd"
  ],
  "safe_macos_names": [
    "launchd", "kernel_task", "kextd", "taskgated", "notifyd", "logd", "syslogd",
    "opendirectoryd", "configd", "distnoted", "cfprefsd", "runningboardd",
    "securityd", "powerd", "sandboxd", "trustd", "coreservicesd", "loginwindow",
    "UserEventAgent", "WindowServer", "Finder", "Dock", "mds", "mdworker",
    "fseventsd", "hidd", "tccd", "locationd", "airportd", "bluetoothd", "coreaudiod"
  ],
  "safe_windows_paths_prefix": [
    "C:\\Windows\\System32\\",
    "C:\\Windows\\SysWOW64\\",
    "C:\\Windows\\explorer.exe"
  ],
  "installed_app_paths_prefix": [
    "C:\\Program Files\\",
    "C:\\Program Files (x86)\\",
    "/bin/",
    "/sbin/",
    "/usr/bin/",
    "/usr/sbin/",
    "/usr/lib/",
    "/usr/libexec/",
    "/System/",
    "/Library/",
    "/opt/"
  ],
  "safe_cmdline_patterns": [
    "^\\[[^\\]]+\\]$",
    "^\\[[^\\]]+\\/\\d+\\]$"
  ],
  "suspicious_path_substrings": [
    "\\AppData\\Local\\Temp\\",
    "\\AppData\\Roaming\\",
    "\\Downloads\\",
    "C:\\Users\\Public\\",
    "/tmp/",
    "/var/tmp/",
    "/dev/shm/"
  ],
  "lolbin_windows": [
    "powershell.exe", "pwsh.exe", "cmd.exe", "wscript.exe", "cscript.exe",
    "rundll32.exe", "regsvr32.exe", "mshta.exe", "wmic.exe", "certutil.exe",
    "bitsadmin.exe", "installutil.exe", "schtasks.exe"
  ],
  "suspicious_cmdline_patterns": [
    "-enc",
    "frombase64string",
    "iex",
    "invoke-expression",
    "downloadstring",
    "curl | sh",
    "wget | sh",
    "/dev/tcp/",
    "python"
  ],
  "malicious_cmdline_patterns": [
    "nc ",
    "31337"
  ],
  "network_suspicious_ports": [4444, 1337, 31337, 6667],
  "weights": {
    "suspicious_path": 30,
    "unsigned_in_systemish": 25,
    "lolbin": 20,
    "suspicious_cmdline": 30,
    "external_connection": 15,
    "listening_uncommon": 15,
    "known_bad_hash": 100,
    "known_safe_baseline": -25,
    "installed_app_hint": -10,
    "valid_signature": -20
  },
  "thresholds": {
    "safe_max": 14,
    "installed_max": 34,
    "possibly_malicious_max": 69
  }
}
